**/__pycache__
**/.idea
**/*.c
**/*.pyd
**/build
**/dist
**/*.egg-info
**/.venv

# Material Symbols and Simple Icons font binaries are fetched at build/CI
# time (see scripts/fetch_fonts.py, scripts/fetch_brand_icons.py), not
# committed. src/qtmdi/manifest.json and the charmap.json files track their
# content instead.
src/qtmdi/icons/**/*.ttf
src/qtmdi/icons/**/*.otf
src/qtmdi/brands/**/*.ttf
src/qtmdi/brands/**/*.otf